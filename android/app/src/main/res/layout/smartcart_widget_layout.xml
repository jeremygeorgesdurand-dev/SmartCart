<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/widget_header_background">

        <TextView
            android:id="@+id/widget_liste_nom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SmartCart"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widget_compteur"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/widget_btn_add"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/widget_btn_background"/>
    </LinearLayout>

    <!-- Barre de progression -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#FFFFFF"
        android:progressBackgroundTint="#33FFFFFF"/>

    <!-- Articles statiques (max 6, scrollable via StackView non nécessaire) -->
    <LinearLayout
        android:id="@+id/widget_articles_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout android:id="@+id/row_0"
            android:layout_width="match_parent" android:layout_height="34dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/check_0" android:layout_width="22dp" android:layout_height="22dp"
                android:text="○" android:textSize="14sp" android:textColor="#CCFFFFFF" android:gravity="center" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/nom_0" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#EEFFFFFF" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/qte_0" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/row_1"
            android:layout_width="match_parent" android:layout_height="34dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/check_1" android:layout_width="22dp" android:layout_height="22dp"
                android:text="○" android:textSize="14sp" android:textColor="#CCFFFFFF" android:gravity="center" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/nom_1" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#EEFFFFFF" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/qte_1" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/row_2"
            android:layout_width="match_parent" android:layout_height="34dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/check_2" android:layout_width="22dp" android:layout_height="22dp"
                android:text="○" android:textSize="14sp" android:textColor="#CCFFFFFF" android:gravity="center" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/nom_2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#EEFFFFFF" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/qte_2" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/row_3"
            android:layout_width="match_parent" android:layout_height="34dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/check_3" android:layout_width="22dp" android:layout_height="22dp"
                android:text="○" android:textSize="14sp" android:textColor="#CCFFFFFF" android:gravity="center" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/nom_3" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#EEFFFFFF" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/qte_3" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/row_4"
            android:layout_width="match_parent" android:layout_height="34dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/check_4" android:layout_width="22dp" android:layout_height="22dp"
                android:text="○" android:textSize="14sp" android:textColor="#CCFFFFFF" android:gravity="center" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/nom_4" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#EEFFFFFF" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/qte_4" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/row_5"
            android:layout_width="match_parent" android:layout_height="34dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView android:id="@+id/check_5" android:layout_width="22dp" android:layout_height="22dp"
                android:text="○" android:textSize="14sp" android:textColor="#CCFFFFFF" android:gravity="center" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/nom_5" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="12sp" android:textColor="#EEFFFFFF" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/qte_5" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="10sp" android:textColor="#88FFFFFF"/>
        </LinearLayout>

        <!-- Message vide / suite -->
        <TextView
            android:id="@+id/widget_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Configurez dans\nParamètres → Widget"
            android:textSize="11sp"
            android:textColor="#AAFFFFFF"
            android:gravity="center"
            android:visibility="visible"/>

    </LinearLayout>

</LinearLayout>
